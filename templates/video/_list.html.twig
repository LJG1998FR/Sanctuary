<table class="container table table-light table-striped table-hover" data-controller="video">
    <thead>
        <tr>
            <th class="col-1" scope="col">#</th>
            <th class="col-6" scope="col">{{ "admin.videos.table.header_title"|trans }} 
                <a href="{{ path('admin_video_index', {'field': 'title', 'order' : (order == "ASC" ? "DESC" : "ASC"), 'limit': limit, 'search': search }) }}" data-turbo-frame="list">
                    <i class="link-dark bi bi-arrow-down-up"></i>
                </a>
            </th>
            <th class="col-3" scope="col">{{ "admin.videos.table.header_created_at"|trans }}  
                <a href="{{ path('admin_video_index', {'field': 'createdAt', 'order' : (order == "ASC" ? "DESC" : "ASC"), 'limit': limit, 'search': search }) }}" data-turbo-frame="list">
                    <i class="link-dark bi bi-arrow-down-up"></i>
                </a>
            </th>
            <th class="text-center" scope="col">{{ "admin.videos.table.header_actions"|trans }} </th>
        </tr>
    </thead>
    <tbody id="main-container">
        {% for video in videosByPage %}
            <tr>
                <td><input data-videoid={{ video.id }} class="form-check-input delete-checkbox" type="checkbox" value="" id="delete_checkbox_{{video.id}}" data-turbo-frame="list"></td>
                <td class="table-light">{{ video.title }}</td>
                <td class="table-light">{{ video.createdAt ? video.createdAt|date('Y-m-d H:i:s') : '' }}</td>
                <td class="table-light d-flex justify-content-center gap-3">
                    <button class="btn btn-info">
                        <a class="link-dark" href="{{ path('admin_video_show', {'slugger': video.slugger}) }}" data-turbo-frame="_top">
                            <i class="bi bi-eye-fill"></i>
                        </a>
                    </button>
                    <button class="btn btn-info">
                        <a class="link-dark" href="{{ path('admin_video_edit', {'id': video.id}) }}" data-turbo-frame="_top">
                            <i class="bi bi-pencil-square"></i>
                        </a>
                    </button>
                    {{ include('video/_delete_form.html.twig') }}
                </td>
            </tr>
        {% else %}
            <h2>{{ "admin.videos.empty_table"|trans }} <a href="{{ path('admin_video_new') }}" data-turbo-frame="_top">{{ "admin.videos.add_first"|trans }}</a></h2>
        {% endfor %}
    </tbody>
</table>

{% if nb_pages > 1 %}
    <nav aria-label="Video navigation">
        <ul class="pagination justify-content-center">
            <li class="page-item {{ (page == 1 ? "disabled" : "") }}">
                <a class="page-link" href="{{ path('admin_video_index', {'page': page - 1, 'limit' : limit, 'field': field, 'order' : order, 'search': search}) }}" tabindex="-1" aria-disabled="{{ (page == 1 ? "true" : "false") }}" data-turbo-frame="list">{{ "common.pagination.previous"|trans }}</a>
            </li>
        
            {% for index in 1.. nb_pages %}
                <li class="page-item {{ (page == index ? "disabled" : "") }}"><a class="page-link" href="{{ path('admin_video_index', {'page': index, 'limit' : limit, 'field': field, 'order' : order, 'search': search}) }}" data-turbo-frame="list">{{ index }}</a></li>
            {% endfor %}
            <li class="page-item {{ page + 1 <= nb_pages ? "" : "disabled" }}">
                <a class="page-link" href="{{ path('admin_video_index', {'page': page + 1, 'limit' : limit, 'field': field, 'order' : order, 'search': search}) }}" aria-disabled="{{ ( page + 1 <= nb_pages ? "false" : "true") }}" data-turbo-frame="list">{{ "common.pagination.next"|trans }}</a>
            </li>
        </ul>
    </nav>
{% endif %}