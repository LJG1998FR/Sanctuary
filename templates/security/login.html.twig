{% extends 'base.html.twig' %}

{% block subtitle %}Log in!{% endblock %}

{% block body %}

    <form method="post" class="w-50 mx-auto mt-5 d-flex flex-column justify-content-center">
        <h1 class="mb-3">{{appname}}</h1>
        {% if error %}
            <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        <h1 class="h3 mb-3 font-weight-normal">{{ "auth.login.title"|trans }}</h1>

        <label for="username">{{ "auth.login.label_username"|trans }}</label>
        <input type="text" value="{{ last_username }}" name="_username" id="username" class="form-control mb-4" autocomplete="username" required autofocus>

        <label for="password">{{ "auth.login.label_password"|trans }}</label>
        <input type="password" name="_password" id="password" class="form-control mb-4" autocomplete="current-password" required>

        <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

        <button class="btn btn-lg btn-primary" type="submit">
            {{ "auth.login.button_submit"|trans }}
        </button>
    </form>
{% endblock %}
