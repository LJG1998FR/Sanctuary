<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %} {{ appname }} {% endblock %} - {% block subtitle %} {% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        {% block stylesheets %}
            <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
            <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.9.1/font/bootstrap-icons.css">
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-MrcW6ZMFYlzcLA8Nl+NtUVF0sA7MsXsP1UyJoMp4YLEuNSfAP+JcXn/tWtIaxVXM" crossorigin="anonymous"></script>
        {% endblock %}
    </head>
    <body>
        <div data-turbo-permanent id="spinner" class="d-flex justify-content-center align-items-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">{{ "common.messages.loading"|trans }}</span>
            </div>
        </div>
        {% if is_granted('IS_AUTHENTICATED_FULLY') %}
            {% block navbar %}
                <nav class="navbar navbar-expand-lg navbar-light bg-light">
                    <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse justify-content-between mx-3" id="navbarNav">
                        <ul class="navbar-nav">
                            <li class="nav-item">
                                <a class={{ app.request.get('_route') == "dashboard" ? "'nav-link fw-bold disabled'" : "nav-link" }} href="{{path('dashboard')}}">{{ appname }}</a>
                            </li>
                            <li class="nav-item">
                                <a class={{ app.request.get('_route') == "admin_tag_index" ? "'nav-link fw-bold disabled'" : "nav-link" }} href="{{ path('admin_tag_index') }}">{{ "common.navigation.tags"|trans }}</a>
                            </li>
                            <li class="nav-item">
                                <a class={{ app.request.get('_route') == "admin_video_index" or app.request.get('_route') == "admin_video_index_reverse" ? "'nav-link fw-bold disabled'" : "nav-link" }} href="{{path('admin_video_index')}}">{{ "common.navigation.videos"|trans }}</a>
                            </li>
                            <li class="nav-item">
                                <a class={{ app.request.get('_route') == "admin_photo_collection_index" ? "'nav-link fw-bold disabled'" : "nav-link" }} href="{{ path('admin_photo_collection_index') }}">{{ "common.navigation.gallery"|trans }}</a>
                            </li>
                            <li class="nav-item">
                                <a class={{ app.request.get('_route') == "admin_video_new" ? "'nav-link fw-bold disabled'" : "nav-link" }} href="{{ path('admin_video_new') }}">{{ "common.navigation.upload_new_video"|trans }}</a>
                            </li>
                            <li class="nav-item">
                                <a class={{ app.request.get('_route') == "admin_photo_collection_new" ? "'nav-link fw-bold disabled'" : "nav-link" }} href="{{ path('admin_photo_collection_new') }}">{{ "common.navigation.add_collection"|trans }}</a>
                            </li>
                            <li class="nav-item">
                                <a class={{ app.request.get('_route') == "admin_tag_new" ? "'nav-link fw-bold disabled'" : "nav-link" }} href="{{ path('admin_tag_new') }}">{{ "common.navigation.add_tags"|trans }}</a>
                            </li>
                            {% if is_granted('IS_AUTHENTICATED_FULLY') %}
                            <li class="nav-item">
                                <a class={{ app.request.get('_route') == "admin_logout" ? "'nav-link fw-bold disabled'" : "nav-link" }} href="{{ path('admin_logout') }}">{{ "common.navigation.logout"|trans }}</a>
                            </li>
                            {% else %}
                            <li class="nav-item">
                                <a class={{ app.request.get('_route') == "admin_login" ? "'nav-link fw-bold disabled'" : "nav-link" }} href="{{ path('admin_login') }}">{{ "common.navigation.login"|trans }}</a>
                            </li>
                            {% endif %}
                        </ul>
                    </div>
                </nav>
            {% endblock %}
        {% endif %}
        {% block body %}{% endblock %}
    </body>
</html>
